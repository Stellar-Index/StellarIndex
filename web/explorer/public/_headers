# Cloudflare Pages reads this file from the build output and applies
# the rules to every response. Netlify uses the same format. For
# Vercel, translate manually to `vercel.json` headers; the
# operator runbook (docs/operations/showcase-deployment.md)
# flags this as a per-host translation step.
#
# Security philosophy: defence-in-depth on a static site that loads
# nothing from third parties at runtime. Every request the showcase
# makes goes to api.stellarindex.io (set via NEXT_PUBLIC_API_BASE_URL
# at build time); everything else is local self-references.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), microphone=(), payment=(), usb=()
  # HSTS — pin HTTPS for one year, including subdomains
  # (api.stellarindex.io, status.stellarindex.io,
  # docs.stellarindex.io are all HTTPS-only at the edge so the
  # includeSubDomains directive is safe). `preload` is
  # intentionally OMITTED until the operator has submitted the
  # apex to https://hstspreload.org/ — preload is irrevocable
  # once browsers ship it, so we ratchet up in two steps.
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # CSP — restrictive but functional. 'unsafe-inline' is required
  # for Next.js static-export bootstrap scripts and Tailwind inline
  # styles; revisit if Next stops emitting them. connect-src lists
  # the API origin so fetch() works.
  #
  # ── frame-ancestors is deliberately ABSENT here (site-audit S14) ──
  # CF Pages applies EVERY matching rule, so an /embed/* response
  # receives this CSP *and* the /embed/* one below — and a response
  # carrying two CSP headers is enforced as their INTERSECTION, not
  # as an override. With `frame-ancestors 'none'` here, that
  # intersection was 'none' ∩ * = 'none', which silently blocked
  # every customer iframe AND the site's own /widgets previews. An
  # earlier comment on the /embed/* rule asserted _headers rules were
  # "full replacement (NOT merged)"; production disproves it — both
  # headers are demonstrably sent.
  #
  # Framing for non-embed paths is therefore enforced by
  # X-Frame-Options: DENY above, which browsers honour precisely
  # BECAUSE no CSP frame-ancestors is present to supersede it.
  #
  # ── img-src allows https: (site-audit S43) ──
  # Asset icons are issuer-hosted (centre.io, aqua.network,
  # stronghold.co, …) and the API serves them as absolute URLs.
  # `img-src 'self' data:` blocked 28 of 28 off-origin icons, i.e.
  # every asset icon on the site, while looking like sparse data.
  # TODO: proxy/cache icons same-origin and narrow this back to
  # 'self' — that also removes the issuer-IP-leak and availability
  # dependency this widening accepts.
  #
  # F-0054 (audit-2026-05-26): an earlier revision permitted
  # http://localhost:3000 in connect-src as a dev-convenience —
  # left over after a one-time test of serving the built bundle
  # against a local API. The Next dev server doesn't read _headers
  # at all (it serves no production headers), so production
  # leakage is the only effect. Removed.
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://api.stellarindex.io; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'

# Fingerprinted Next.js assets — far-future cache. CF Pages already
# does this by default but the explicit header doubles as
# documentation; Netlify needs it.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# /embed/* widgets are explicitly designed to be iframe'd into
# customer sites — that's the entire product surface (see /widgets).
#
# How framing is actually permitted here (site-audit S14): the /*
# rule deliberately emits NO frame-ancestors, so this rule's
# `frame-ancestors *` is the only one on the response and there is
# nothing to intersect it away. Because a CSP frame-ancestors IS
# present on /embed/* responses, browsers ignore X-Frame-Options
# entirely for them — which is what makes the parent rule's
# `X-Frame-Options: DENY` harmless here. ALLOWALL is still set for
# pre-CSP browsers.
#
# DO NOT reintroduce frame-ancestors to the /* rule. CF Pages applies
# every matching rule, both CSP headers reach the browser, and two
# CSPs are enforced as an intersection — which is exactly how the
# entire embed product came to be silently unframeable.
/embed/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: ALLOWALL
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), microphone=(), payment=(), usb=()
  # HSTS repeated so it applies regardless of how the host merges
  # rules. (The parent's HSTS also reaches these responses; an
  # identical duplicate is harmless, unlike the CSP case above.)
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://api.stellarindex.io; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors *; form-action 'self'
