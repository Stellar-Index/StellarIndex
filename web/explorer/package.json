{
  "name": "@stellarindex/explorer",
  "version": "0.0.0",
  "private": true,
  "description": "Public showcase site + explorer for the Stellar Index API (stellarindex.io).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:api": "openapi-typescript ../../openapi/stellar-index.v1.yaml -o src/api/types.ts",
    "build:worker": "OPEN_NEXT=1 opennextjs-cloudflare build -c wrangler.ssr.jsonc",
    "preview:worker": "opennextjs-cloudflare preview -c wrangler.ssr.jsonc",
    "prebuild": "mkdir -p public/openapi && cp ../../openapi/stellar-index.v1.yaml public/openapi/stellar-index.v1.yaml"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "satori": "^0.26.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.7",
    "wrangler": "4.108.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd",
      "esbuild",
      "sharp",
      "@resvg/resvg-js",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "js-yaml@<4.3.0": ">=4.3.0",
      "brace-expansion@<1.1.16": ">=1.1.16",
      "brace-expansion@>=2.0.0 <2.1.2": ">=2.1.2"
    },
    "patchedDependencies": {
      "eslint-plugin-react@7.37.5": "patches/eslint-plugin-react@7.37.5.patch"
    }
  }
}
