# Copy to `.env` in this directory. docker-compose picks it up
# automatically. Never commit .env (it's in .gitignore).
#
# The defaults here are the same ones wired into dev.yaml. Override
# if another service on your machine is already on these ports.

# ─── Postgres + TimescaleDB ────────────────────────────────────────
TIMESCALE_IMAGE_TAG=2.17.2-pg15
POSTGRES_DB=stellaratlas
POSTGRES_USER=stellaratlas
POSTGRES_PASSWORD=stellaratlas-dev
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_IMAGE_TAG=7.4-alpine
REDIS_PORT=6379
REDIS_MAXMEM=512mb

# ─── MinIO ─────────────────────────────────────────────────────────
MINIO_IMAGE_TAG=RELEASE.2024-11-07T00-52-20Z
MC_IMAGE_TAG=RELEASE.2024-11-05T11-29-45Z
MINIO_ROOT_USER=stellaratlas
MINIO_ROOT_PASSWORD=stellaratlas-dev-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
