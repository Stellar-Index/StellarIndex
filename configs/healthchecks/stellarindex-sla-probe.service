[Unit]
Description=Stellar Index SLA probe (latency + freshness pass/fail)
Documentation=https://github.com/Stellar-Index/StellarIndex/blob/main/configs/healthchecks/README.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/opt/stellarindex/healthchecks/sla-probe.sh
EnvironmentFile=-/etc/default/stellarindex-healthchecks
DynamicUser=true
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
# The wrapper defaults SLA_PROBE_TEXTFILE_OUTPUT to
# /var/lib/node_exporter/textfile_collector/sla_probe.prom so the
# alerts in deploy/monitoring/rules/sla-probe.yml have real series
# to evaluate. ProtectSystem=strict makes /var read-only; without
# ReadWritePaths every probe run failed with EROFS on the textfile.
# The archival-node role provisions the directory with mode 0775 +
# group stellarindex; DynamicUser is in the stellarindex
# SupplementaryGroup so it can write here.
ReadWritePaths=/var/lib/node_exporter/textfile_collector
SupplementaryGroups=stellarindex
