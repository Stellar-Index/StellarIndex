# /etc/default/minio — templated by ansible; root:minio 0640.
# Secrets come from ansible-vault inventory/<region>.secrets.yml.

MINIO_VOLUMES="{{ minio_data_path }}"
MINIO_OPTS="--address {{ minio_bind_address }}:{{ minio_port }} --console-address {{ minio_bind_address }}:{{ minio_console_port }}"

MINIO_ROOT_USER="{{ minio_root_user }}"
MINIO_ROOT_PASSWORD="{{ minio_root_password }}"

# Limit concurrent deletes (single-node has no erasure redundancy)
MINIO_API_DELETE_CLEANUP_INTERVAL="5m"
