{#
  stellar-core config template. Rendered in two modes:

    mode == "full"         → /etc/stellar/stellar-core.cfg
      Real stellar-core daemon. Includes HTTP_PORT, PEER_PORT,
      NODE_IS_VALIDATOR, NODE_HOME_DOMAIN, DATABASE, CATCHUP_*.

    mode == "captive"      → /etc/stellar/captive-core-galexie*.cfg
      Consumed by a galexie instance's embedded (captive) core.
      Captive core rejects NODE_IS_VALIDATOR, NODE_HOME_DOMAIN,
      CATCHUP_*, DATABASE — those are driven by the parent process
      (galexie) instead. [[HOME_DOMAINS]], [[VALIDATORS]],
      [HISTORY.*], NETWORK_PASSPHRASE are shared.

  Captive renders take two extra knobs from the caller:
    captive_peer_port            — the PEER_PORT (must differ per
                                   captive so they don't collide).
    captive_history_localmirror  — when true, emit a
                                   [HISTORY.localmirror] get-only
                                   block reading /srv/history-archive
                                   (the backfill captive uses this).

  Rendered from roles/archival-node/defaults/main.yml + inventory.
  See https://github.com/stellar/stellar-core/blob/master/docs/stellar-core_example.cfg
#}
{% set cfg_mode = cfg_mode | default('full') %}

{% if cfg_mode == 'full' %}
HTTP_PORT = {{ stellar_http_port }}
PUBLIC_HTTP_PORT = false
PEER_PORT = {{ stellar_peer_port }}
{% else %}
# Captive-core runs alongside the primary stellar-core on the same
# box. We must give each captive-core its OWN PEER_PORT because:
#
#   1. HTTP_PORT=0 disables the admin HTTP server — fine.
#   2. PEER_PORT=0 *would* disable outbound peering too, BUT the
#      go-stellar-sdk toml marshaller has `toml:"PEER_PORT,omitempty"`
#      on the PeerPort field (toml.go:90). Zero values get dropped
#      from the rendered captive config, and stellar-core falls back
#      to the pubnet default 11625 — which is already bound by the
#      primary daemon → std::system_error(98) bind: Address already
#      in use → SIGABRT → ingestion restart loop.
#
# So we pass an explicit NON-ZERO port that's different from the
# primary's (11625) and different per-captive. captive_peer_port
# is injected by the caller (live-tail galexie: 11726, archive-
# backfill galexie: 11727).
HTTP_PORT = 0
PUBLIC_HTTP_PORT = false
PEER_PORT = {{ captive_peer_port }}
{% endif %}

NETWORK_PASSPHRASE = "{% if stellar_network == 'pubnet' %}Public Global Stellar Network ; September 2015{% elif stellar_network == 'testnet' %}Test SDF Network ; September 2015{% else %}{{ stellar_network }}{% endif %}"

{% if cfg_mode == 'full' %}
NODE_IS_VALIDATOR = {{ node_is_validator | lower }}
NODE_HOME_DOMAIN  = "{{ home_domain }}"
{% if is_validator %}
# NODE_SEED is resolved via the HSM signer daemon in validator mode.
# See docs/architecture/infrastructure/validator-rollout.md §5.
# NODE_SEED = "SX..."   # DO NOT set on disk
{% endif %}

DATABASE = "postgresql://dbname={{ postgres_db_core }} host=127.0.0.1 user={{ postgres_user_core }} password={{ postgres_pass_core }}"

BUCKET_DIR_PATH = "/var/lib/stellar-core/buckets"

{% if catchup_mode == "COMPLETE" %}
CATCHUP_COMPLETE = true
{% else %}
CATCHUP_RECENT = 1024
{% endif %}
{% endif %}

# Additional known peers — SCP gossip-bootstrap addresses beyond the
# ADDRESS fields on [[VALIDATORS]] below. Must appear BEFORE any
# [SECTION] or [[...]] header; stellar-core's parser has no "return
# to root" so every key after a section header is scoped to that
# section.
{% if stellar_extra_known_peers %}
KNOWN_PEERS = [
{% for peer in stellar_extra_known_peers %}
    "{{ peer }}"{% if not loop.last %},{% endif %}
{% endfor %}
]
{% endif %}

# ──── Our own history archive ────────────────────────────────────────
# Local publishing target. Only the PRIMARY stellar-core publishes
# here — captive-cores would otherwise try to publish too (because
# put/mkdir are defined), and their catchup hangs retrying publish
# operations against an archive that the primary hasn't yet
# initialised with a `.well-known/stellar-history.json`. Observed
# symptom: "History: Activating publish for ledger X" looped every
# 2 s, ingestion stalled.
# [HISTORY.*] entries for SDF archives live inside each [[VALIDATORS]]
# block below via the HISTORY field (the preferred 1:1 pairing).
{% if cfg_mode == 'full' %}

[HISTORY.ratesengine]
get = "cp /srv/history-archive/{0} {1}"
put = "cp {0} /srv/history-archive/{1}"
mkdir = "mkdir -p /srv/history-archive/{0}"
{% endif %}
{% if captive_history_localmirror | default(false) %}

# ──── Local history-archive mirror (backfill primary source) ─────
# /srv/history-archive is our rs-stellar-archivist mirror of the
# public network archive. Listed before any validator HISTORY so
# captive-core reads files from NVMe instead of downloading them
# from publicnode/lobstr/etc — cuts replay time from 24-48h to
# ~5-12h. Falls back to the per-validator HISTORY URLs below if a
# specific file is missing from the mirror. get-only: a captive
# core must never publish (see the [HISTORY.ratesengine] note).
[HISTORY.localmirror]
get = "cp /srv/history-archive/{0} {1}"
{% endif %}

# ──── Home domain quality tiers ─────────────────────────────────────
# Must appear BEFORE [[VALIDATORS]] blocks reference them. QUALITY
# HIGH = tier-1, automatically included in the outer quorum set.
# stellar-core auto-builds quorum from HOME_DOMAIN groupings: inner
# set per org (2/3 threshold), outer set across orgs.
{% for hd in stellar_home_domains %}

[[HOME_DOMAINS]]
HOME_DOMAIN="{{ hd.home_domain }}"
QUALITY="{{ hd.quality }}"
{% endfor %}

# ──── Validators ────────────────────────────────────────────────────
# Each validator is its own block. HOME_DOMAIN must match one of the
# entries in [[HOME_DOMAINS]] above.
#
# Non-voting archival mode: we trust these validators to decide the
# ledger. Do not promote to voting without an ADR.
{% for v in stellar_validators %}

[[VALIDATORS]]
NAME="{{ v.name }}"
HOME_DOMAIN="{{ v.home_domain }}"
PUBLIC_KEY="{{ v.public_key }}"
{% if v.address is defined %}
ADDRESS="{{ v.address }}"
{% endif %}
{% if v.history is defined %}
HISTORY="{{ v.history }}"
{% endif %}
{% endfor %}
