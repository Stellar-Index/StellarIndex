# {{ ansible_managed }}
# archival-node role / 10-observability.yml — do not hand-edit on
# the host; change the template and re-apply (--tags promtail).
#
# Ships systemd-journald entries — the stellarindex-* units plus
# everything else in the journal (galexie, caddy, minio, postgres,
# loki itself) — to Loki at {{ loki_push_url }}. The keep-filter is
# `.+` (every unit): at single-host scale the storage cost is
# negligible and operators select stellarindex units at query time
# via {job=~"stellarindex-.*"}.
#
# This template supersedes the hand-installed
# configs/loki/promtail.r1.yml (same rendered content on r1).

server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: {{ loki_push_url }}

scrape_configs:
  # Journald for the application services + storage plumbing.
  # Each unit gets its own job label so Grafana can filter
  # "show me stellarindex-aggregator only" without parsing.
  - job_name: journal
    journal:
      max_age: 12h
      labels:
        host: {{ region_id }}
    relabel_configs:
      - source_labels: ["__journal__systemd_unit"]
        target_label: unit
      - source_labels: ["__journal__systemd_unit"]
        regex: ".+"
        action: keep
      - source_labels: ["__journal__systemd_unit"]
        target_label: job
        regex: "(.*)\\.service"
        replacement: "$1"
