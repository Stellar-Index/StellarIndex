{# Render-time — managed by ansible (prometheus role). Don't edit. #}
{# Validated by `amtool check-config` before reload. #}
{#                                                                        #}
{# This template uses the page / ticket / informational severity         #}
{# vocabulary defined in docs/operations/severity-ladder.md — the same   #}
{# labels every rule in deploy/monitoring/rules/ + configs/prometheus/   #}
{# rules.r1/ emits. The receiver fanout mirrors the standalone           #}
{# configs/alertmanager/alertmanager.r1.yml so a host can be brought up  #}
{# from either path with consistent behaviour.                            #}

global:
  resolve_timeout: 5m

# ─── Routing tree ────────────────────────────────────────────────
#
# Default `chat-default` (rather than a more drastic "pagerduty-
# default") so unknown-severity alerts surface in chat without
# spurious paging. Per-severity matchers below route the standard
# ladder. Deadmansswitch is a separately-rooted heartbeat that
# never matches any other route.
route:
  receiver: chat-default
  group_by: [alertname, severity]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h

  routes:
    # Deadmansswitch — fires constantly while Prometheus +
    # Alertmanager are alive. Routed to Healthchecks.io; when the
    # heartbeat stops, Healthchecks pages us via a separately-
    # hosted channel, catching outages of Prometheus or
    # Alertmanager themselves.
    # See docs/operations/runbooks/deadmansswitch.md.
    - matchers: [alertname = "stellarindex_deadmansswitch"]
      receiver: deadmansswitch
      group_interval: 60s
      repeat_interval: 60s
      continue: false

    # Page — SEV-1: customer-visible outage. Highest-urgency chat
    # channel + (when wired) PagerDuty.
    - matchers: [severity = "page"]
      receiver: chat-page
      continue: false

    # Ticket — actionable but not customer-urgent. Lower repeat
    # cadence so a long-running ticket doesn't spam the channel.
    - matchers: [severity = "ticket"]
      receiver: chat-default
      repeat_interval: 24h
      continue: false

    # Informational — accumulates in the Alertmanager UI. No
    # chat fanout (would dilute the page + ticket signal).
    - matchers: [severity = "informational"]
      receiver: silent
      continue: false

# ─── Inhibit rules ───────────────────────────────────────────────
#
# Suppress lower-severity variants of the same alert when a page is
# already firing — prevents stacking when an incident escalates and
# both the ticket-tier baseline alert and the page-tier escalation
# fire simultaneously.
inhibit_rules:
  - source_matchers: [severity = "page"]
    target_matchers: [severity =~ "ticket|informational"]
    equal: [alertname, component]

# ─── Receivers ───────────────────────────────────────────────────
#
# Every chat receiver short-circuits to a no-op stub when its
# webhook URL is unset — alerts still accumulate in the Alertmanager
# UI but don't fan out. Operators can wire any subset.
receivers:
  # Deadmansswitch heartbeat — Healthchecks.io webhook.
  - name: deadmansswitch
{% if alertmanager_healthchecks_deadmansswitch_url %}
    webhook_configs:
      - url: {{ alertmanager_healthchecks_deadmansswitch_url }}
        send_resolved: false
{% else %}
    # No HEALTHCHECKS_DEADMANSSWITCH_URL — set
    # alertmanager_healthchecks_deadmansswitch_url in inventory
    # (or env-substitute at apply time). Without it the dead-man
    # heartbeat doesn't reach Healthchecks, defeating the
    # "Prometheus or Alertmanager itself is down" detection.
{% endif %}

  # Page-tier fanout — Discord #pages + (future) PagerDuty.
  - name: chat-page
{% if alertmanager_discord_webhook_url_pages %}
    discord_configs:
      - webhook_url: {{ alertmanager_discord_webhook_url_pages }}
        send_resolved: true
        title: '🚨 PAGE — {{ "{{" }} .GroupLabels.alertname {{ "}}" }}'
        message: |
          {{ "{{" }} range .Alerts {{ "}}" }}
          **{{ "{{" }} .Annotations.summary {{ "}}" }}**
          {{ "{{" }} .Annotations.description {{ "}}" }}
          {{ "{{" }} if .Annotations.runbook_url {{ "}}" }}Runbook: {{ "{{" }} .Annotations.runbook_url {{ "}}" }}{{ "{{" }} end {{ "}}" }}
          {{ "{{" }} end {{ "}}" }}
{% endif %}
{% if alertmanager_pagerduty_key %}
    pagerduty_configs:
      - service_key: {{ alertmanager_pagerduty_key }}
        send_resolved: true
{% endif %}
{% if not alertmanager_discord_webhook_url_pages and not alertmanager_pagerduty_key %}
    # No chat / pagerduty wiring on page-tier — alerts visible only
    # in Alertmanager UI. Set alertmanager_discord_webhook_url_pages
    # and/or alertmanager_pagerduty_key.
{% endif %}

  # Ticket-tier + default — Discord #alerts (no page-out).
  - name: chat-default
{% if alertmanager_discord_webhook_url_alerts %}
    discord_configs:
      - webhook_url: {{ alertmanager_discord_webhook_url_alerts }}
        send_resolved: true
        title: '{{ "{{" }} .GroupLabels.alertname {{ "}}" }}'
        message: |
          {{ "{{" }} range .Alerts {{ "}}" }}
          **[{{ "{{" }} .Labels.severity | toUpper {{ "}}" }}]** {{ "{{" }} .Annotations.summary {{ "}}" }}
          {{ "{{" }} .Annotations.description {{ "}}" }}
          {{ "{{" }} if .Annotations.runbook_url {{ "}}" }}Runbook: {{ "{{" }} .Annotations.runbook_url {{ "}}" }}{{ "{{" }} end {{ "}}" }}
          {{ "{{" }} end {{ "}}" }}
{% else %}
    # No alertmanager_discord_webhook_url_alerts — ticket alerts
    # visible only in the Alertmanager UI. Set the webhook to fan out.
{% endif %}

  # Silent — informational alerts accumulate in the Alertmanager UI
  # without fanout. No receiver config = no delivery; AM still
  # tracks alert state for inspection.
  - name: silent
